{
  "version": 2,
  "buildCommand": "pnpm run build:client",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/|calculator\.html|calc\.js|calc\.css).*)",
      "destination": "/index.html"
    }
  ]
}